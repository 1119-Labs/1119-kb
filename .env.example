# Used by docker-compose for ${VAR} substitution (build args + app env).
# Copy to .env and set values, or copy from apps/app/.env:
#   cp apps/app/.env .env
# Or source before build/up:
#   export $(grep -v '^#' apps/app/.env | xargs) && docker compose build
#
BETTER_AUTH_SECRET=
POSTGRES_PASSWORD=
